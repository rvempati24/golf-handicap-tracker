# Postgres connection string.
# Runtime connection string, usually Neon's pooled URL. Example Neon format:
# postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=""

# Direct/non-pooled Postgres connection string for Prisma migrations.
# In Neon, use the non-pooled connection string for the same database.
DIRECT_URL=""

# Required for any write action: creating/editing/deleting rounds, courses, and tee sets.
# Use a long private string and set the same value in Vercel.
OWNER_WRITE_KEY=""

# Google Gemini API key — required only for the AI Insights module.
# Get a free key at https://aistudio.google.com/apikey . Never commit your real key.
GEMINI_API_KEY=""
